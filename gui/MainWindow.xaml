<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Azure Resource Tagger"
        Width="1300" Height="850"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="AzureBlue" Color="#0078D4"/>
        <SolidColorBrush x:Key="AzureDark" Color="#004578"/>
        <SolidColorBrush x:Key="AzureLight" Color="#DEECF9"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#107C10"/>
        <SolidColorBrush x:Key="AccentAmber" Color="#CA5010"/>
        <SolidColorBrush x:Key="AccentRed" Color="#D13438"/>
        <SolidColorBrush x:Key="CardBg" Color="White"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#333333"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#666666"/>

        <DropShadowEffect x:Key="CardShadow" ShadowDepth="1" BlurRadius="6" Opacity="0.12" Direction="270"/>

        <!-- Button Style -->
        <Style x:Key="AzureButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0078D4"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GreenButton" TargetType="Button">
            <Setter Property="Background" Value="#107C10"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#0B5C0B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0B5C0B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card Border Style -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

        <!-- DataGrid Style -->
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="True"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E0E0E0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFAFA"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="CanUserSortColumns" Value="True"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="EnableColumnVirtualization" Value="True"/>
            <Setter Property="VirtualizingStackPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingStackPanel.VirtualizationMode" Value="Recycling"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="#005A9E"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- Header Bar -->
        <Border DockPanel.Dock="Top" Padding="16,10,16,10">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#005BA1" Offset="0"/>
                    <GradientStop Color="#0078D4" Offset="0.4"/>
                    <GradientStop Color="#2B88D8" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="6" Opacity="0.3" Direction="270"/>
            </Border.Effect>
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#FFFFFF" CornerRadius="6" Width="36" Height="36" Margin="0,0,12,0" VerticalAlignment="Center">
                        <TextBlock Text="&#x1F3F7;" FontSize="18" Foreground="#0078D4" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Azure Resource Tagger" FontSize="19" Foreground="White" FontWeight="Bold"/>
                        <TextBlock x:Name="VersionLabel" Text="v1.0.0" FontSize="10.5" Foreground="#A0C4E8" Margin="1,0,0,0"/>
                    </StackPanel>
                    <Border Background="#005A9E" CornerRadius="2" Width="1" Margin="18,4,14,4" VerticalAlignment="Stretch"/>
                    <TextBlock x:Name="TenantLabel" Text="" FontSize="12" Foreground="#B3D7F2" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <Button x:Name="CommercialButton" Content="Commercial Tenant" Style="{StaticResource AzureButton}"
                            Background="Transparent" Foreground="White" BorderBrush="White" Margin="0,0,8,0"/>
                    <Button x:Name="GovButton" Content="Gov Tenant" Style="{StaticResource AzureButton}"
                            Background="Transparent" Foreground="White" BorderBrush="White" Margin="0,0,8,0"/>
                    <Button x:Name="ScanButton" Content="&#x1F50D; Scan Tags" Style="{StaticResource AzureButton}"
                            Background="White" Foreground="#0078D4" Margin="0,0,8,0" IsEnabled="False"/>
                    <Button x:Name="ExportButton" Content="&#x1F4CA; Export to CSV" Style="{StaticResource AzureButton}"
                            Background="Transparent" Foreground="White" BorderBrush="White" IsEnabled="False"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" Background="#F8F8F8" BorderBrush="#DDD" BorderThickness="0,1,0,0" Padding="12,6">
            <DockPanel>
                <ProgressBar x:Name="ProgressBar" Width="220" Height="14" Minimum="0" Maximum="100" Value="0"
                             Foreground="#0078D4" Background="#E0E0E0" DockPanel.Dock="Right" Margin="10,0,0,0"/>
                <TextBlock x:Name="StatusText" Text="Click 'Commercial Tenant' or 'Gov Tenant' to start" Foreground="#666"
                           FontSize="12" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <TabControl x:Name="MainTabs" Padding="0" BorderThickness="0" Background="#F0F0F0">

            <!-- TAB 1: Scope & Scan -->
            <TabItem Header="  Scope &amp; Scan  " FontSize="13">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>

                        <!-- Scope Selector -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Scan Scope" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Scope Level:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                                               FontSize="13" Margin="0,0,12,8"/>
                                    <ComboBox x:Name="ScopeLevel" Grid.Row="0" Grid.Column="1" Width="300" HorizontalAlignment="Left"
                                              FontSize="13" Margin="0,0,0,8">
                                        <ComboBoxItem Content="Subscription" IsSelected="True"/>
                                        <ComboBoxItem Content="Resource Group"/>
                                    </ComboBox>
                                    <TextBlock Text="Subscription:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"
                                               FontSize="13" Margin="0,0,12,8"/>
                                    <ComboBox x:Name="SubscriptionSelector" Grid.Row="1" Grid.Column="1" Width="500"
                                              HorizontalAlignment="Left" FontSize="13" Margin="0,0,0,8" IsEnabled="False"/>
                                    <TextBlock Text="Resource Group:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                                               FontSize="13" Margin="0,0,12,0"/>
                                    <ComboBox x:Name="RGSelector" Grid.Row="2" Grid.Column="1" Width="500"
                                              HorizontalAlignment="Left" FontSize="13" IsEnabled="False"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Summary Cards -->
                        <WrapPanel Margin="0,10,0,10">
                            <Border Style="{StaticResource Card}" Width="200">
                                <StackPanel>
                                    <TextBlock Text="Resource Groups" FontSize="11" Foreground="#999"/>
                                    <TextBlock x:Name="RGCountText" Text="--" FontSize="22" FontWeight="Bold" Foreground="#0078D4" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}" Width="200">
                                <StackPanel>
                                    <TextBlock Text="Total Resources" FontSize="11" Foreground="#999"/>
                                    <TextBlock x:Name="ResourceCountText" Text="--" FontSize="22" FontWeight="Bold" Foreground="#0078D4" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}" Width="200">
                                <StackPanel>
                                    <TextBlock Text="Tag Coverage" FontSize="11" Foreground="#999"/>
                                    <TextBlock x:Name="TagCoverageText" Text="--" FontSize="22" FontWeight="Bold" Foreground="#107C10" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}" Width="200">
                                <StackPanel>
                                    <TextBlock Text="Untagged RGs" FontSize="11" Foreground="#999"/>
                                    <TextBlock x:Name="UntaggedRGText" Text="--" FontSize="22" FontWeight="Bold" Foreground="#D13438" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}" Width="200">
                                <StackPanel>
                                    <TextBlock Text="Unique Tag Keys" FontSize="11" Foreground="#999"/>
                                    <TextBlock x:Name="UniqueTagsText" Text="--" FontSize="22" FontWeight="Bold" Foreground="#CA5010" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <!-- Tag Key Summary -->
                        <TextBlock Text="Tag Key Summary" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="6,10,0,6"/>
                        <Border Style="{StaticResource Card}" MinHeight="200">
                            <DataGrid x:Name="TagSummaryGrid" MinHeight="180"/>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TAB 2: Resource Groups -->
            <TabItem Header="  Resource Groups  " FontSize="13">
                <DockPanel Margin="20">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Filter:" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="RGFilterTag" Width="200" FontSize="13" Margin="0,0,8,0">
                            <ComboBoxItem Content="All Resource Groups" IsSelected="True"/>
                            <ComboBoxItem Content="Missing Any Required Tag"/>
                        </ComboBox>
                        <TextBlock Text="Required Tags:" FontSize="13" VerticalAlignment="Center" Margin="16,0,8,0" Foreground="#666"/>
                        <Grid>
                            <TextBox x:Name="RequiredTagsInput" Width="400" FontSize="12" Padding="4"
                                     Background="White"/>
                            <TextBlock x:Name="RequiredTagsPlaceholder" Text="e.g. CostCentre, Environment, Owner"
                                       FontSize="12" Foreground="#AAAAAA" Padding="6,5,4,4" IsHitTestVisible="False"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                    <DataGrid x:Name="RGGrid" />
                </DockPanel>
            </TabItem>

            <!-- TAB 3: Resources -->
            <TabItem Header="  Resources  " FontSize="13">
                <DockPanel Margin="20">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Filter:" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="ResFilterTag" Width="200" FontSize="13" Margin="0,0,8,0">
                            <ComboBoxItem Content="All Resources" IsSelected="True"/>
                            <ComboBoxItem Content="Untagged Resources"/>
                            <ComboBoxItem Content="Missing Specific Tag"/>
                        </ComboBox>
                        <TextBlock Text="Tag Name:" FontSize="13" VerticalAlignment="Center" Margin="16,0,8,0" Foreground="#666"/>
                        <TextBox x:Name="ResFilterTagName" Width="200" FontSize="12" Padding="4" IsEnabled="False"/>
                    </StackPanel>
                    <DataGrid x:Name="ResourceGrid"/>
                </DockPanel>
            </TabItem>

            <!-- TAB 4: Apply Tags -->
            <TabItem Header="  Apply Tags  " FontSize="13">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>

                        <!-- Tag Definition -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Define Tags to Apply" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Tag Name:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                                               FontSize="13" Margin="0,0,12,8"/>
                                    <TextBox x:Name="ApplyTagName" Grid.Row="0" Grid.Column="1" FontSize="13" Padding="6" Margin="0,0,12,8"/>
                                    <TextBlock Text="Tag Value:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"
                                               FontSize="13" Margin="0,0,12,0"/>
                                    <TextBox x:Name="ApplyTagValue" Grid.Row="1" Grid.Column="1" FontSize="13" Padding="6" Margin="0,0,12,0"/>
                                    <Button x:Name="AddTagButton" Content="+ Add Tag" Grid.Row="0" Grid.Column="2"
                                            Style="{StaticResource AzureButton}" VerticalAlignment="Top"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Tags Queue -->
                        <TextBlock Text="Tags to Apply" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="6,16,0,6"/>
                        <Border Style="{StaticResource Card}" MinHeight="120">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,10,0,0">
                                    <Button x:Name="ClearTagsButton" Content="Clear All" Style="{StaticResource AzureButton}" Margin="0,0,8,0"/>
                                    <Button x:Name="RemoveTagButton" Content="Remove Selected" Style="{StaticResource AzureButton}"/>
                                </StackPanel>
                                <DataGrid x:Name="TagQueueGrid" MinHeight="80" AutoGenerateColumns="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Tag Name" Binding="{Binding TagName}" Width="*"/>
                                        <DataGridTextColumn Header="Tag Value" Binding="{Binding TagValue}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>

                        <!-- Target Scope -->
                        <Border Style="{StaticResource Card}" Margin="6,16,6,6">
                            <StackPanel>
                                <TextBlock Text="Target Scope" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Apply To:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                                               FontSize="13" Margin="0,0,12,8"/>
                                    <ComboBox x:Name="ApplyScope" Grid.Row="0" Grid.Column="1" Width="350" HorizontalAlignment="Left"
                                              FontSize="13" Margin="0,0,0,8">
                                        <ComboBoxItem Content="All Resource Groups in Scope" IsSelected="True"/>
                                        <ComboBoxItem Content="All Resource Groups Missing This Tag"/>
                                        <ComboBoxItem Content="All Resources in Scope"/>
                                        <ComboBoxItem Content="All Untagged Resources"/>
                                        <ComboBoxItem Content="Selected Resource Groups"/>
                                    </ComboBox>
                                    <CheckBox x:Name="OverwriteCheck" Grid.Row="1" Grid.Column="1" Content="Overwrite existing tag values"
                                              FontSize="13" Margin="0,0,0,8" IsChecked="False"/>
                                    <CheckBox x:Name="DryRunCheck" Grid.Row="2" Grid.Column="1" Content="Dry run (preview only - don't apply)"
                                              FontSize="13" IsChecked="True"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                    <Button x:Name="ApplyTagsButton" Content="&#x2705; Apply Tags" Style="{StaticResource GreenButton}"
                                            Margin="0,0,12,0" IsEnabled="False"/>
                                    <TextBlock x:Name="ApplyStatusText" Text="" FontSize="13" Foreground="#666" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Results -->
                        <TextBlock Text="Results" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="6,16,0,6"/>
                        <Border Style="{StaticResource Card}" MinHeight="150">
                            <DataGrid x:Name="ApplyResultsGrid" MinHeight="130"/>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TAB 5: Remove Tags -->
            <TabItem Header="  Remove Tags  " FontSize="13">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>

                        <!-- Tag Selection -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Select Tag to Remove" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Tag Name:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                                               FontSize="13" Margin="0,0,12,8"/>
                                    <ComboBox x:Name="RemoveTagSelector" Grid.Row="0" Grid.Column="1" Width="350"
                                              HorizontalAlignment="Left" FontSize="13" Margin="0,0,12,8" IsEditable="True"/>
                                    <Button x:Name="RefreshTagListButton" Content="Refresh List" Grid.Row="0" Grid.Column="2"
                                            Style="{StaticResource AzureButton}" VerticalAlignment="Top"/>
                                    <TextBlock Text="Tag Value Filter:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"
                                               FontSize="13" Margin="0,0,12,0"/>
                                    <Grid Grid.Row="1" Grid.Column="1">
                                        <TextBox x:Name="RemoveTagValueFilter" Width="350" HorizontalAlignment="Left"
                                                 FontSize="13" Padding="4" Background="White"/>
                                        <TextBlock x:Name="RemoveTagValuePlaceholder" Text="Leave blank to remove from all (any value)"
                                                   FontSize="12" Foreground="#AAAAAA" Padding="6,5,4,4" IsHitTestVisible="False"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Remove Scope -->
                        <Border Style="{StaticResource Card}" Margin="6,16,6,6">
                            <StackPanel>
                                <TextBlock Text="Remove Scope" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Remove From:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                                               FontSize="13" Margin="0,0,12,8"/>
                                    <ComboBox x:Name="RemoveScope" Grid.Row="0" Grid.Column="1" Width="350" HorizontalAlignment="Left"
                                              FontSize="13" Margin="0,0,0,8">
                                        <ComboBoxItem Content="All Resource Groups in Scope" IsSelected="True"/>
                                        <ComboBoxItem Content="All Resources in Scope"/>
                                        <ComboBoxItem Content="All Resource Groups and Resources"/>
                                    </ComboBox>
                                    <CheckBox x:Name="RemoveDryRunCheck" Grid.Row="1" Grid.Column="1"
                                              Content="Dry run (preview only - don't remove)"
                                              FontSize="13" IsChecked="True"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                    <Button x:Name="RemoveTagsButton" Content="Remove Tags"
                                            Background="#D13438" Foreground="White" BorderBrush="#A4262C"
                                            BorderThickness="1" Padding="16,8" FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                            IsEnabled="False">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#A4262C"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Opacity" Value="0.5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <TextBlock x:Name="RemoveStatusText" Text="" FontSize="13" Foreground="#666"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Remove Results -->
                        <TextBlock Text="Results" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="6,16,0,6"/>
                        <Border Style="{StaticResource Card}" MinHeight="150">
                            <DataGrid x:Name="RemoveResultsGrid" MinHeight="130"/>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
